erDiagram

%% ================================================================================
%% LANDLORD (SHARED)
%% ================================================================================

%% ========================
%% USERS (LANDLORD)
%% ========================
users {
    uuid id PK
    string name
    string email UK
    timestamp email_verified_at
    string password
    boolean is_active
    string remember_token
    timestamp created_at
    timestamp updated_at
}

user_profiles {
    uuid user_id PK, FK
    string phone
    date birth_date
    string identity_number
    string address
    string city
    string province
    string postal_code
    string country
}

%% ========================
%% ACCOUNTS (LANDLORD)
%% ========================
accounts {
    uuid id PK
    string name
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

account_profiles {
    uuid account_id PK, FK
    string email
    string phone
    string address
    string city
    string province
    string postal_code
    string country
    string website
    text description
    string tax_id
    string legal_name
}

account_users {
    uuid account_id PK, FK
    uuid user_id PK, FK
    string role
    timestamp created_at
}

%% ========================
%% CLINICS (LANDLORD)
%% ========================
clinics {
    uuid id PK
    uuid account_id FK
    string name
    string code UK
    string domain UK
    string database UK
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

clinic_profiles {
    uuid clinic_id PK, FK
    string category "general | aesthetic | dental"
    string timezone
    string email
    string phone
    string address
    string city
    string province
    string postal_code
    string country
    float latitude
    float longitude
    string website
    text description
}

clinic_users {
    uuid clinic_id PK, FK
    uuid user_id PK, FK
    string role
    boolean is_active
    timestamp created_at
}

%% ========================
%% MEDIA (LANDLORD)
%% ========================
media {
    uuid id PK
    string scope_type "account | clinic"
    uuid scope_id
    string disk "public | private"
    string path
    string file_name
    string mime_type
    bigint size
    string collection "default: default"
    text placeholder "nullable (base64 preview)"
    string mediable_type
    uuid mediable_id
    uuid uploaded_by FK "nullable -> users.id"
    timestamp created_at
    timestamp deleted_at
}

%% ========================
%% BILLING PLANS (LANDLORD)
%% ========================
plans {
    uuid id PK
    string code
    string name
    decimal base_price
    string billing_cycle
    string currency
    boolean is_active
    int trial_duration_days
    timestamp created_at
    timestamp updated_at
}

subscriptions {
    uuid id PK
    uuid account_id FK
    uuid plan_id FK
    string status
    timestamp started_at
    timestamp expired_at
    timestamp trial_end_at
    timestamp cancelled_at
    timestamp suspended_at
    string suspend_reason
    timestamp billing_anchor_date
    timestamp next_billing_at
    timestamp plan_changed_at
    timestamp created_at
    timestamp updated_at
}

extras {
    uuid id PK
    string code
    string name
    string unit
    string price_type
    decimal base_price
    boolean is_active
    timestamp created_at
    timestamp updated_at
    timestamp deleted_at
}

subscription_extras {
    uuid id PK
    uuid subscription_id FK
    uuid extra_id FK
    int quantity
    decimal unit_price
    boolean is_active
    json metadata
    timestamp started_at
    timestamp ended_at
    timestamp created_at
    timestamp updated_at
    timestamp deleted_at
}

%% ========================
%% FEATURES (LANDLORD)
%% ========================
features {
    uuid id PK
    string key UK
    string name
    string type "limit | boolean | config"
    text description
}

plan_features {
    uuid id PK
    uuid plan_id FK
    uuid feature_id FK
    string value
}

extra_features {
    uuid id PK
    uuid extra_id FK
    uuid feature_id FK
    string value
}

account_entitlements {
    uuid id PK
    uuid account_id FK
    uuid feature_id FK
    string value
    string source_type
    uuid source_id
    timestamp created_at
}

%% ========================
%% BILLING TRANSACTIONS (LANDLORD)
%% ========================
billing_invoices {
    uuid id PK
    uuid account_id FK
    uuid subscription_id FK
    string invoice_number UK
    string status
    decimal subtotal
    decimal discount_amount
    decimal tax
    decimal total
    string currency
    timestamp due_date
    timestamp paid_at
}

billing_invoice_items {
    uuid id PK
    uuid invoice_id FK
    string reference_type
    uuid reference_id
    string name
    int quantity
    decimal unit_price
    decimal total_price
}

billing_payments {
    uuid id PK
    uuid invoice_id FK
    decimal amount
    string currency
    string provider
    string method
    string status
    string provider_reference
    text payment_url
    jsonb provider_payload
    jsonb provider_payload_update
    string provider_account_id
    timestamp expires_at
    timestamp paid_at
}

%% ========================
%% ICD CODES (LANDLORD)
%% ========================
icd_codes {
    uuid id PK
    string code UK
    string type "ICD10 | ICD9CM"
    string name_en
    string name_id
    text description
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

%% ========================
%% SEARCH (LANDLORD)
%% ========================
search_logs {
    uuid id PK
    string query_text
    string entity_type "icd | patient | medicine | dll"
    uuid entity_id
    int result_count
    int click_rank
    timestamp created_at
}

search_aggregates {
    uuid id PK
    string query_text
    string entity_type
    uuid entity_id
    int total_search
    int total_selected
    float success_rate
    timestamp last_used_at
}

%% ========================
%% KFA MASTER (LANDLORD)
%% ========================
kfa_templates {
    uuid id PK
    string kfa_code UK "92xxxxxx"
    string name
    boolean is_active
    string status "valid | invalid"
    timestamp updated_at
}

kfa_items {
    uuid id PK
    string kfa_code "nullable, 93xxxxxx or '/'"
    string name
    uuid template_id FK
    string brand_name
    string production_type "local | import"
    string manufacturer
    string registrar
    string type_code "drug | device"
    string type_group "obat | alkes"
    boolean is_generic
    decimal dose_per_unit
    string unit_key
    string dosage_form_key
    decimal net_weight
    string net_weight_unit_key
    decimal volume
    string volume_unit_key
    decimal fixed_price
    decimal ceiling_price
    boolean is_listed_in_lkpp
    string lkpp_code
    string image_url
    boolean is_active
    string status
    timestamp updated_at
}

kfa_lookups {
    string key PK "mg, ml, tablet"
    string label
    string type "unit | dosage_form"
    boolean is_active
}

kfa_drug_ingredients {
    uuid id PK
    uuid drug_item_id FK
    string kfa_code "91xxxxxx (BZA code)"
    string name "zat_aktif"
    string strength "300 mg (raw dari API)"
    boolean is_active
    string status
    timestamp updated_at
}

%% ========================
%% SERVICE TEMPLATES (LANDLORD)
%% ========================
service_templates {
    uuid id PK
    string code UK
    string name
    string category "general | dental | aesthetic"
    text description
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

%% ========================
%% POSITION TEMPLATES (LANDLORD)
%% ========================
position_templates {
    uuid id PK
    string key UK "doctor, nurse, admin"
    string name
    text description
    boolean is_active
}

%% ========================
%% SPECIALTY TEMPLATES (LANDLORD)
%% ========================
specialty_templates {
    uuid id PK
    string code UK
    string name
    text description
    boolean is_active
}

%% ================================================================================
%% TENANT (PER CLINIC)
%% ================================================================================

%% ========================
%% PATIENTS (TENANT)
%% ========================
patients {
    uuid id PK
    uuid clinic_id FK
    string medical_record_number "unique per clinic"
    string full_name
    string gender
    date birth_date
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

patient_profiles {
    uuid patient_id PK, FK
    string identity_number
    string address
    string city
    string province
    string postal_code
    string country
    string blood_type
    string marital_status
    text notes
}

patient_contacts {
    uuid id PK
    uuid patient_id FK
    string type "phone | email | whatsapp"
    string value
    boolean is_primary
}

patient_emergency_contacts {
    uuid id PK
    uuid patient_id FK
    string name
    string relationship
    string phone
}

patient_identifiers {
    uuid id PK
    uuid patient_id FK
    string type "national_id | insurance | passport"
    string value
    boolean is_primary
}

patient_insurances {
    uuid id PK
    uuid patient_id FK
    string provider_name
    string policy_number
    boolean is_active
}

%% ========================
%% SERVICES (TENANT)
%% ========================
services {
    uuid id PK
    uuid clinic_id FK
    uuid template_id FK "nullable"
    string code
    string name
    decimal base_price
    int duration_minutes
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

polyclinic_services {
    uuid polyclinic_id FK
    uuid service_id FK
}

%% ========================
%% FACILITY (TENANT)
%% ========================
polyclinics {
    uuid id PK
    uuid clinic_id FK
    string code
    string name
    text description
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

rooms {
    uuid id PK
    uuid clinic_id FK
    uuid polyclinic_id FK
    string code
    string name
    string type "consultation | treatment"
    int capacity
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

employee_polyclinics {
    uuid employee_id FK
    uuid polyclinic_id FK
    boolean is_primary
}

%% ========================
%% INVENTORY (TENANT)
%% ========================
medical_items {
    uuid id PK
    uuid clinic_id FK
    string code
    string name
    string type "drug | medical_supply | equipment"
    string kfa_code "nullable (reference to landlord KFA)"
    boolean is_kfa_linked
    string unit "tablet | ml | pcs"
    boolean is_batch_tracked
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

medical_stocks {
    uuid id PK
    uuid clinic_id FK
    uuid item_id FK
    decimal quantity
    decimal min_stock
    decimal max_stock
}

medical_batches {
    uuid id PK
    uuid clinic_id FK
    uuid item_id FK
    string batch_number
    date expired_at
    decimal quantity
    decimal purchase_price
}

medical_movements {
    uuid id PK
    uuid clinic_id FK
    uuid item_id FK
    uuid batch_id FK "nullable"
    string type "purchase | usage | adjustment | expired"
    decimal quantity
    string reference_type
    uuid reference_id
    timestamp created_at
}

%% ========================
%% STAFF (TENANT)
%% ========================
employees {
    uuid id PK
    uuid clinic_id FK
    uuid user_id FK "nullable (link to landlord users)"
    string employee_code
    string full_name
    string gender
    date birth_date
    string phone
    string email
    date hire_date
    string employment_type
    string status
    timestamp created_at
    timestamp updated_at
}

employee_profiles {
    uuid employee_id PK, FK
    string identity_number
    string address
    string city
    string province
    string postal_code
    string country
    string emergency_contact_name
    string emergency_contact_phone
    text notes
}

employee_positions {
    uuid id PK
    uuid clinic_id FK
    uuid template_id FK "nullable (from landlord)"
    string key "optional custom"
    string name
    text description
    boolean is_active
}

employee_position_assignments {
    uuid employee_id FK
    uuid position_id FK
    timestamp assigned_at
}

specialties {
    uuid id PK
    uuid clinic_id FK
    uuid template_id FK "nullable (from landlord)"
    string code
    string name
    text description
    boolean is_active
}

employee_specialties {
    uuid employee_id FK
    uuid specialty_id FK
    boolean is_primary
}

