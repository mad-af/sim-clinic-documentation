erDiagram

%% ========================
%% MEDICAL ITEMS
%% ========================

medical_items {
    uuid id PK
    uuid clinic_id FK

    string code
    string name

    string type        "drug | medical_supply | equipment"

    string kfa_code    "nullable (reference to landlord KFA)"
    boolean is_kfa_linked

    string unit        "tablet | ml | pcs"

    boolean is_batch_tracked

    boolean is_active

    timestamp created_at
    timestamp updated_at
}

%% ========================
%% MEDICAL STOCKS
%% ========================

medical_stocks {
    uuid id PK
    uuid clinic_id FK
    uuid item_id FK

    decimal quantity

    decimal min_stock
    decimal max_stock
}

%% ========================
%% MEDICAL BATCHES
%% ========================

medical_batches {
    uuid id PK
    uuid clinic_id FK
    uuid item_id FK

    string batch_number
    date expired_at

    decimal quantity

    decimal purchase_price
}

%% ========================
%% MEDICAL MOVEMENTS
%% ========================

medical_movements {
    uuid id PK
    uuid clinic_id FK
    uuid item_id FK
    uuid batch_id FK "nullable"

    string type   "purchase | usage | adjustment | expired"

    decimal quantity

    string reference_type
    uuid reference_id

    timestamp created_at
}

%% ========================
%% RELATIONSHIPS
%% ========================

medical_items ||--|| medical_stocks : "has"
medical_items ||--o{ medical_batches : "has"
medical_items ||--o{ medical_movements : "logs"

medical_batches ||--o{ medical_movements : "used in"