erDiagram

%% ========================
%% ENCOUNTER (CORE)
%% ========================

encounters {
    uuid id PK
    uuid clinic_id FK

    uuid patient_id FK
    uuid patient_visit_id FK

    uuid polyclinic_session_id FK
    uuid doctor_id FK

    datetime started_at
    datetime ended_at

    string status "in_progress | completed | cancelled"

    timestamp created_at
    timestamp updated_at
}

%% ========================
%% SUBJECTIVE (SOAP - S)
%% ========================

encounter_subjectives {
    uuid id PK
    uuid encounter_id FK

    text chief_complaint
    text history_of_present_illness
    text notes
}

encounter_allergies {
    uuid id PK
    uuid encounter_id FK

    string allergen
    string reaction
    string severity
}

encounter_medical_histories {
    uuid id PK
    uuid encounter_id FK

    string condition
    text notes
}

%% ========================
%% PATIENT LONG-TERM MEMORY
%% ========================

patient_allergies {
    uuid id PK
    uuid patient_id FK

    string allergen
    string reaction
    string severity

    timestamp created_at
}

patient_medical_histories {
    uuid id PK
    uuid patient_id FK

    string condition
    text notes

    timestamp created_at
}

%% ========================
%% OBJECTIVE (SOAP - O)
%% ========================

encounter_vitals {
    uuid id PK
    uuid encounter_id FK

    decimal systolic
    decimal diastolic
    decimal heart_rate
    decimal respiratory_rate
    decimal temperature
    decimal oxygen_saturation

    decimal weight
    decimal height
    decimal bmi
}

%% Examination (semi-structured)
encounter_examinations {
    uuid id PK
    uuid encounter_id FK

    string system "ENUM: head, thorax, abdomen, etc"
    text findings
}

%% Observation templates (structured)
observation_templates {
    uuid id PK

    string key UK
    string name

    string unit
    string normal_range

    boolean is_active
}

encounter_observations {
    uuid id PK
    uuid encounter_id FK

    uuid template_id FK

    decimal value
    text notes
}

%% Media (photo, supporting)
encounter_media {
    uuid id PK
    uuid encounter_id FK

    string file_url
    string type "photo | lab | other"
}

%% ========================
%% ASSESSMENT (SOAP - A)
%% ========================

encounter_diagnoses {
    uuid id PK

    uuid encounter_id FK
    uuid icd_code_id FK

    boolean is_primary
    text notes
}

%% ========================
%% PLAN (SOAP - P)
%% ========================

encounter_services {
    uuid id PK

    uuid encounter_id FK
    uuid service_id FK

    int quantity
    decimal price

    text notes
}

encounter_dispositions {
    uuid id PK
    uuid encounter_id FK

    string discharge_status
    string discharge_method
    string prognosis
}

%% ========================
%% LAB (ASYNC)
%% ========================

encounter_lab_orders {
    uuid id PK

    uuid encounter_id FK

    string test_name
    string status "ordered | completed | cancelled"

    text notes

    timestamp ordered_at
}

encounter_lab_results {
    uuid id PK

    uuid lab_order_id FK

    string result_value
    string unit
    string reference_range

    text notes

    string file_url
    uuid uploaded_by

    timestamp resulted_at
}

%% ========================
