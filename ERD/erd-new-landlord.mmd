erDiagram

%% ================================================================================
%% LANDLORD (SHARED)
%% ================================================================================

%% ========================
%% USERS (LANDLORD)
%% ========================
users {
    uuid id PK
    string name
    string email UK
    timestamp email_verified_at
    string password
    boolean is_active
    string remember_token
    timestamp created_at
    timestamp updated_at
}

user_profiles {
    uuid user_id PK, FK
    string phone
    date birth_date
    string identity_number
    string address
    string city
    string province
    string postal_code
    string country
}

%% ========================
%% ACCOUNTS (LANDLORD)
%% ========================
accounts {
    uuid id PK
    string name
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

account_profiles {
    uuid account_id PK, FK
    string email
    string phone
    string address
    string city
    string province
    string postal_code
    string country
    string website
    text description
    string tax_id
    string legal_name
}

account_users {
    uuid account_id PK, FK
    uuid user_id PK, FK
    string role
    timestamp created_at
}

%% ========================
%% CLINICS (LANDLORD)
%% ========================
clinics {
    uuid id PK
    uuid account_id FK
    string name
    string code UK
    string domain UK
    string database UK
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

clinic_profiles {
    uuid clinic_id PK, FK
    string category "general | aesthetic | dental"
    string timezone
    string email
    string phone
    string address
    string city
    string province
    string postal_code
    string country
    float latitude
    float longitude
    string website
    text description
}

clinic_users {
    uuid clinic_id PK, FK
    uuid user_id PK, FK
    string role
    boolean is_active
    timestamp created_at
}

%% ========================
%% MEDIA (LANDLORD)
%% ========================
media {
    uuid id PK
    string scope_type "account | clinic"
    uuid scope_id
    string disk "public | private"
    string path
    string file_name
    string mime_type
    bigint size
    string collection "default: default"
    text placeholder "nullable (base64 preview)"
    string mediable_type
    uuid mediable_id
    uuid uploaded_by FK "nullable -> users.id"
    timestamp created_at
    timestamp deleted_at
}

%% ========================
%% BILLING PLANS (LANDLORD)
%% ========================
plans {
    uuid id PK
    string code
    string name
    decimal base_price
    string billing_cycle
    string currency
    boolean is_active
    int trial_duration_days
    timestamp created_at
    timestamp updated_at
}

subscriptions {
    uuid id PK
    uuid account_id FK
    uuid plan_id FK
    string status
    timestamp started_at
    timestamp expired_at
    timestamp trial_end_at
    timestamp cancelled_at
    timestamp suspended_at
    string suspend_reason
    timestamp billing_anchor_date
    timestamp next_billing_at
    timestamp plan_changed_at
    timestamp created_at
    timestamp updated_at
}

extras {
    uuid id PK
    string code
    string name
    string unit
    string price_type
    decimal base_price
    boolean is_active
    timestamp created_at
    timestamp updated_at
    timestamp deleted_at
}

subscription_extras {
    uuid id PK
    uuid subscription_id FK
    uuid extra_id FK
    int quantity
    decimal unit_price
    boolean is_active
    json metadata
    timestamp started_at
    timestamp ended_at
    timestamp created_at
    timestamp updated_at
    timestamp deleted_at
}

%% ========================
%% FEATURES (LANDLORD)
%% ========================
features {
    uuid id PK
    string key UK
    string name
    string type "limit | boolean | config"
    text description
}

plan_features {
    uuid id PK
    uuid plan_id FK
    uuid feature_id FK
    string value
}

extra_features {
    uuid id PK
    uuid extra_id FK
    uuid feature_id FK
    string value
}

account_entitlements {
    uuid id PK
    uuid account_id FK
    uuid feature_id FK
    string value
    string source_type
    uuid source_id
    timestamp created_at
}

%% ========================
%% CLINIC BILLING TRANSACTIONS (LANDLORD)
%% ========================
clinic_invoices {
    uuid id PK
    uuid account_id FK
    uuid subscription_id FK
    string invoice_number UK
    string status
    decimal subtotal
    decimal discount_amount
    decimal tax
    decimal total
    string currency
    timestamp due_date
    timestamp paid_at
}

clinic_invoice_items {
    uuid id PK
    uuid invoice_id FK
    string reference_type
    uuid reference_id
    string name
    int quantity
    decimal unit_price
    decimal total_price
}

clinic_payments {
    uuid id PK
    uuid invoice_id FK
    decimal amount
    string currency
    string provider
    string method
    string status
    string provider_reference
    text payment_url
    jsonb provider_payload
    jsonb provider_payload_update
    string provider_account_id
    timestamp expires_at
    timestamp paid_at
}

%% ========================
%% ICD CODES (LANDLORD)
%% ========================
icd_codes {
    uuid id PK
    string code UK
    string type "ICD10 | ICD9CM"
    string name_en
    string name_id
    text description
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

%% ========================
%% SEARCH (LANDLORD)
%% ========================
search_logs {
    uuid id PK
    string query_text
    string entity_type "icd | patient | medicine | dll"
    uuid entity_id
    int result_count
    int click_rank
    timestamp created_at
}

search_aggregates {
    uuid id PK
    string query_text
    string entity_type
    uuid entity_id
    int total_search
    int total_selected
    float success_rate
    timestamp last_used_at
}

%% ========================
%% KFA MASTER (LANDLORD) - PHARMACY DOMAIN
%% ========================

kfa_active_substances {
    uuid id PK
    string kfa_code UK "91xxxxxx (BZA)"
    string name
    string status
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

kfa_medication_templates {
    uuid id PK
    string kfa_code UK "92xxxxxx (POV)"
    string name
    string dosage_form
    string strength_text
    string route
    string status
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

kfa_medication_template_ingredients {
    uuid id PK
    uuid medication_template_id FK
    uuid active_substance_id FK
    decimal amount
    string unit
    string note
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

kfa_products {
    uuid id PK
    string kfa_code UK "93xxxxxx (POA)"
    uuid medication_template_id FK
    string brand_name
    string manufacturer_name
    string dosage_form
    string strength_text
    string status
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

kfa_product_packages {
    uuid id PK
    string kfa_code UK "94xxxxxx (POAK)"
    uuid product_id FK
    string package_name
    string package_type
    decimal package_quantity
    string package_unit
    string status
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

kfa_lookups {
    string key PK "mg, ml, tablet"
    string label
    string type "unit | dosage_form"
    boolean is_active
}

%% ========================
%% SERVICE TEMPLATES (LANDLORD)
%% ========================
service_templates {
    uuid id PK
    string code UK
    string name
    string category "general | dental | aesthetic"
    text description
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

%% ========================
%% POSITION TEMPLATES (LANDLORD)
%% ========================
position_templates {
    uuid id PK
    string key UK "doctor, nurse, admin"
    string name
    text description
    boolean is_active
}

%% ========================
%% SPECIALTY TEMPLATES (LANDLORD)
%% ========================
specialty_templates {
    uuid id PK
    string code UK
    string name
    text description
    boolean is_active
}

%% ========================
%% OBSERVATION TEMPLATES (LANDLORD)
%% ========================
observation_templates {
    uuid id PK
    string key UK
    string name
    string unit
    string normal_range
    boolean is_active
}

%% ========================
%% QUEUE TEMPLATES (LANDLORD)
%% ========================
queue_templates {
    uuid id PK
    string key UK "frontdesk | consultation | treatment"
    string name
    string code "A | D | T"
    boolean is_active
}

%% ========================
%% TREATMENT TEMPLATES (LANDLORD)
%% ========================
treatment_templates {
    uuid id PK
    string code UK
    string name
    string category "medical | aesthetic | dental"
    string control_level "free | conditional | doctor_required"
    int default_duration_minutes
    boolean requires_therapist
    boolean is_active
    timestamp created_at
    timestamp updated_at
}

