flowchart TD
    Start([Mulai]) --> Input["👨‍⚕️ Dokter Input\nResep Racikan"]
    Input --> HitungDosis["⚖️ Hitung Dosis\nper Komponen"]
    HitungDosis --> CekSisa["🔍 Cek Sisa\nHari Ini"]

    subgraph Racik["🔄 RACIK & TIMBANG"]
        CekSisa --> SisaCukup{"Sisa\nMencukupi?"}
        SisaCukup -->|Ya| PakaiSisa["✅ Pakai Sisa"]
        SisaCukup -->|Tidak| AmbilStok["📦 Ambil dari\nStok"]
        PakaiSisa & AmbilStok --> Campur["🔄 Racik\n(Campur/Bulat)"]
    end

    Campur --> Jadi["💊 Obat Jadi"]
    Jadi --> Stok["📦 Stok\nBerkurang"]
    Stok --> Serah["👤 Serahkan\nke Pasien"]
    Serah --> End([Selesai])

    subgraph Annotations["📌 ATURAN SISA"]
        ANN1["💊 Sisa = Obat yang digerus\ntapi tidak terpakai penuh"]
        ANN2["📦 Sisa disimpan max 1 hari\nJika tidak terpakai → Dibuang"]
        ANN3["📉 Stok tetap dikurangi\nbaik yang dipakai maupun sisa"]
    end

    %% ==================== STYLES ====================
    style Start fill:#E8F5E9,stroke:#4CAF50
    style End fill:#FFEBEE,stroke:#F44336
    style Racik fill:#FFF3E0,stroke:#FF9800
    style Annotations fill:#F5F5F5,stroke:#9E9E9E
